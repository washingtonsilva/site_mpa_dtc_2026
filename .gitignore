.ipynb_checkpoints/
.jupyter_cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Dados locais ou proprietários

# Ajuste os nomes das pastas à estrutura efetivamente usada no projeto.

# Evite ignorar extensões inteiras, como *.csv ou *.xlsx, pois alguns

# conjuntos de dados didáticos podem precisar ser versionados.

dados/proprietarios/

